				end)
			end
			hdr.MouseButton1Click:Connect(function()
				expanded=not expanded
				local cnt=0 for _,b in pairs(OptH:GetChildren()) do if b:IsA("TextButton") and b.Visible then cnt=cnt+1 end end
				local ch=math.min(cnt,5)*30 Scroll.CanvasSize=UDim2.new(0,0,0,cnt*30) Scroll.Size=UDim2.new(1,-16,0,ch)
				TweenService:Create(fr,SMOOTH,{Size=UDim2.new(1,0,0,expanded and (cYOff+ch+8) or 38)}):Play()
				TweenService:Create(arr,SMOOTH,{Rotation=expanded and 270 or 90}):Play()
			end)
			Hover(hdr,fr,C.CARD,C.CARD_HOV)
			local F={}
			function F:Set(val)
				if val==nil and not isMulti then
					selected=nil Library.Flags[flag]=nil
					if DHL then DHL.Visible=false end
					for _,btn in pairs(OptH:GetChildren()) do if btn:IsA("TextButton") then TweenService:Create(btn,FAST,{TextColor3=C.TEXT_DIM}):Play() end end
					UpdTitle() cb(nil) return
				end
				if isMulti then
					selected={} if val and type(val)=="table" then for _,v in ipairs(val) do selected[v]=true end end
					for _,btn in pairs(OptH:GetChildren()) do
						if btn:IsA("TextButton") then TweenService:Create(btn,FAST,{TextColor3=selected[btn.Text] and C.TEXT or C.TEXT_DIM}):Play() end
					end
					local sl={} for k in pairs(selected) do table.insert(sl,k) end Library.Flags[flag]=sl UpdTitle() cb(sl)
				else
					selected=val Library.Flags[flag]=val
					for _,btn in pairs(OptH:GetChildren()) do
						if btn:IsA("TextButton") then TweenService:Create(btn,FAST,{TextColor3=btn.Text==val and C.TEXT or C.TEXT_DIM}):Play() end
					end
					UpdTitle() cb(val)
				end
			end
			function F:Refresh(newList)
				list=newList
				for _,c in pairs(OptH:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
				for i,v in ipairs(list) do
					local opt=N("TextButton",{Text=v,Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=C.TEXT_DIM,
						Size=UDim2.new(1,0,0,29),BackgroundTransparency=1,LayoutOrder=i,Parent=OptH})
					opt.MouseButton1Click:Connect(function() Sel(v,opt) end)
					if isMulti and selected[v] then opt.TextColor3=C.TEXT elseif not isMulti and selected==v then opt.TextColor3=C.TEXT end
				end
				Scroll.CanvasSize=UDim2.new(0,0,0,#list*30)
				if expanded then local ch=math.min(#list,5)*30 Scroll.Size=UDim2.new(1,-16,0,ch) fr.Size=UDim2.new(1,0,0,cYOff+ch+8) end
			end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			Library.Items[flag]=F RegSearch(text,"dropdown",F,flag)
			return F
		end

