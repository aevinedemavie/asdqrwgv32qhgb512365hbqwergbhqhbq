				opt.MouseLeave:Connect(function() TweenService:Create(opt,FAST,{TextColor3=selected==v and C.TEXT or C.TEXT_DIM}):Play() end)
				opt.MouseButton1Click:Connect(function() Sel(v,opt) end)
				if isMulti and selected[v] then opt.TextColor3=C.TEXT end
				if not isMulti and default and v==default then
