			local SBg=N("Frame",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.GLASS,ClipsDescendants=true,Parent=Tab._Page})
			Corner(10,SBg) Stroke(C.BORDER,1,SBg)
			local accentLine=N("Frame",{Size=UDim2.new(0,3,0,22),AnchorPoint=Vector2.new(0,0.5),
				Position=UDim2.new(0,0,0.5,0),BackgroundColor3=ACCENT,BackgroundTransparency=0.35,BorderSizePixel=0,Parent=SBg})
			Corner(2,accentLine)
			local SHdr=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,0,34),Parent=SBg})
			N("TextLabel",{Font=Enum.Font.GothamBold,Text=name,TextSize=13,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(14,0),Size=UDim2.new(1,-44,1,0),Parent=SHdr})
			local arrLbl=N("TextLabel",{Text="›",Font=Enum.Font.GothamBold,TextSize=15,TextColor3=C.TEXT_MUT,
				BackgroundTransparency=1,Rotation=expanded and 90 or 0,
				AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),Size=UDim2.fromOffset(18,18),Parent=SHdr})
			local SCont=N("Frame",{Size=UDim2.new(1,-10,0,0),Position=UDim2.fromOffset(6,34),BackgroundTransparency=1,Parent=SBg})
			local SLL=N("UIListLayout",{Padding=UDim.new(0,6),SortOrder=Enum.SortOrder.LayoutOrder,Parent=SCont})
			local function UpdSec()
				local h=SLL.AbsoluteContentSize.Y SCont.Size=UDim2.new(1,-10,0,h)
				TweenService:Create(SBg,SMOOTH,{Size=UDim2.new(1,0,0,expanded and h+42 or 34)}):Play()
			end
			if expanded then task.delay(0.1,UpdSec) end
			SLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdSec)
			SHdr.MouseButton1Click:Connect(function()
				expanded=not expanded TweenService:Create(arrLbl,FAST,{Rotation=expanded and 90 or 0}):Play() UpdSec()
			end)
			Hover(SHdr,SBg,C.GLASS,C.GLASS2)
			local function SCard(h) local f=N("Frame",{Size=UDim2.new(1,0,0,h),BackgroundColor3=C.CARD_HOV,Parent=SCont}) Corner(8,f) return f end
			function Section:Button(cfg2)
				local text=cfg2.Name or cfg2.Text or "Button" local cb=cfg2.Callback or function() end
				local fr=SCard(38)
				local btn=N("TextButton",{Font=Enum.Font.GothamBold,Text=text,TextSize=11,TextColor3=C.TEXT,
					BackgroundColor3=C.BTN,AutoButtonColor=false,BorderSizePixel=0,
					Size=UDim2.new(1,-8,0,30),Position=UDim2.fromOffset(4,4),Parent=fr})
				Corner(6,btn) Hover(btn,btn,C.BTN,C.BTN_HOV) Press(btn,btn,C.BTN,Color3.fromRGB(50,53,70))
				btn.MouseButton1Click:Connect(cb) RegSearch(text,"button",nil,nil)
				local F={} function F:Hide() fr.Visible=false UpdSec() end function F:Show() fr.Visible=true UpdSec() end return F
			end
			function Section:DualButton(c1,c2)
				local fr=N("Frame",{Size=UDim2.new(1,0,0,38),BackgroundTransparency=1,Parent=SCont})
				N("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,6),Parent=fr})
				local function Half(cfg2)
					local text=cfg2.Name or cfg2.Text or "Button" local cb=cfg2.Callback or function() end
					local bg=N("Frame",{Size=UDim2.new(0.5,-3,1,0),BackgroundColor3=C.CARD_HOV,Parent=fr}) Corner(8,bg)
					local btn=N("TextButton",{Font=Enum.Font.GothamBold,Text=text,TextSize=11,TextColor3=C.TEXT,
						BackgroundColor3=C.BTN,AutoButtonColor=false,BorderSizePixel=0,
						Size=UDim2.new(1,-8,0,30),Position=UDim2.fromOffset(4,4),Parent=bg})
					Corner(6,btn) Hover(btn,btn,C.BTN,C.BTN_HOV) Press(btn,btn,C.BTN,Color3.fromRGB(50,53,70))
					btn.MouseButton1Click:Connect(cb) RegSearch(text,"button",nil,nil)
				end
				Half(c1) Half(c2)
				return {Hide=function() fr.Visible=false UpdSec() end, Show=function() fr.Visible=true UpdSec() end}
			end
			function Section:Toggle(cfg2)
				local text=cfg2.Name or "Toggle" local cb=cfg2.Callback or function() end
				local flag=cfg2.Flag or text local state=cfg2.Default or false
				if Library.Flags[flag]~=nil then state=Library.Flags[flag] end Library.Flags[flag]=state
				local fr=SCard(38)
				N("TextLabel",{Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
					TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
					Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-68,1,0),Parent=fr})
				local hit=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.fromScale(1,1),ZIndex=5,Parent=fr})
				local sw=N("Frame",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
					Size=UDim2.fromOffset(36,18),BackgroundColor3=state and ACCENT or C.SW_OFF,BorderSizePixel=0,Parent=fr})
				Corner(16,sw)
				local knob=N("Frame",{Size=UDim2.fromOffset(14,14),
					Position=state and UDim2.fromOffset(20,2) or UDim2.fromOffset(2,2),
					BackgroundColor3=state and C.WHITE or C.SW_KNOB,BorderSizePixel=0,Parent=sw})
				Corner(16,knob)
				local function updSw(v)
					TweenService:Create(sw,FAST,{BackgroundColor3=v and ACCENT or C.SW_OFF}):Play()
					TweenService:Create(knob,FAST,{Position=v and UDim2.fromOffset(20,2) or UDim2.fromOffset(2,2),BackgroundColor3=v and C.WHITE or C.SW_KNOB}):Play()
				end
				hit.MouseButton1Click:Connect(function() state=not state Library.Flags[flag]=state updSw(state) cb(state) end)
				Hover(hit,fr,C.CARD_HOV,C.CARD)
				local F={} function F:Set(v) state=v Library.Flags[flag]=v updSw(v) cb(v) end
				function F:Hide() fr.Visible=false UpdSec() end function F:Show() fr.Visible=true UpdSec() end
				Library.Items[flag]=F RegSearch(text,"toggle",F,flag) return F
			end
			function Section:Slider(cfg2)   return Tab:Slider(cfg2)    end
			function Section:Dropdown(cfg2) return Tab:Dropdown(cfg2)  end
			function Section:Textbox(cfg2)  return Tab:Textbox(cfg2)   end
			function Section:Label(cfg2)    return Tab:Label(cfg2)     end
			function Section:Paragraph(cfg2) return Tab:Paragraph(cfg2) end
			return Section
		end
		return Tab
	end

	task.defer(function() if FirstTabSwitch then FirstTabSwitch() end end)
	task.spawn(function()
		local ad=self:GetAutoLoad()
		if ad.AutoLoadEnabled and ad.AutoLoadName~="" then task.wait(0.5) self:LoadConfig(ad.AutoLoadName) end
	end)
	return self
end

return Library
