				Create("UIStroke", {Color = C.CHROME, Thickness = 1.5}),
			})
			local function Upd(i)
				local p = math.clamp((i.Position.X - Tray.AbsolutePosition.X) / Tray.AbsoluteSize.X, 0, 1)
				local v = math.clamp(math.round((mn + (mx - mn) * p) / step) * step, mn, mx)
				ValBox.Text = tostring(v)
				local vp = (v - mn) / (mx - mn)
				TweenService:Create(Fill2, TweenInfo.new(0.07), {Size = UDim2.fromScale(vp, 1)}):Play()
				TweenService:Create(Knob2, TweenInfo.new(0.07), {Position = UDim2.fromScale(vp, 0.5)}):Play()
				if not cfg2.NoSave then Library.Flags[flag] = v end
				cb(v)
			end
			local F = {}
			function F:Set(v)
				v = math.clamp(math.round(v / step) * step, mn, mx)
				if not cfg2.NoSave then Library.Flags[flag] = v end
				ValBox.Text = tostring(v)
				local vp = (v - mn) / (mx - mn)
				TweenService:Create(Fill2, TweenInfo.new(0.07), {Size = UDim2.fromScale(vp, 1)}):Play()
				TweenService:Create(Knob2, TweenInfo.new(0.07), {Position = UDim2.fromScale(vp, 0.5)}):Play()
				cb(v)
			end
			function F:Hide() Bg.Visible = false end function F:Show() Bg.Visible = true end
			Library.Items[flag] = F
			local drag = false
			Bg.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					drag = true Upd(i) end
			end)
			UIS.InputChanged:Connect(function(i)
				if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then Upd(i) end
			end)
			UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = false end
			end)
			ValBox.FocusLost:Connect(function()
				local n = tonumber(ValBox.Text)
				if n then F:Set(n) else ValBox.Text = tostring(Library.Flags[flag] or default) end
			end)
			return F
		end

