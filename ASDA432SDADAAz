			local fr = N("Frame",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.CARD,ClipsDescendants=true,Parent=Tab._Page})
			Corner(8,fr)
			local hdr = N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,0,34),Parent=fr})
			local dtitle = N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=text,TextSize=12,
				TextColor3=C.TEXT,TextXAlignment=Enum.TextXAlignment.Left,
				BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-52,1,0),Parent=hdr,
			})
			local arr = N("TextLabel",{
				Text="›",Font=Enum.Font.GothamBold,TextSize=16,
				TextColor3=C.TEXT_MUT,BackgroundTransparency=1,Rotation=90,
				AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
				Size=UDim2.fromOffset(18,18),Parent=hdr,
			})

			local cYOff = 34
			local SBar
			if isSearch then
				SBar = N("TextBox",{
					Size=UDim2.new(1,-16,0,24),Position=UDim2.fromOffset(8,34),
					BackgroundColor3=C.INPUT,PlaceholderText="Search...",Text="",
					Font=Enum.Font.Gotham,TextSize=11,
					TextColor3=C.TEXT,PlaceholderColor3=Color3.fromRGB(50,52,64),
					TextXAlignment=Enum.TextXAlignment.Left,Parent=fr,
				})
				Corner(6,SBar) N("UIPadding",{PaddingLeft=UDim.new(0,8),Parent=SBar})
				cYOff = 64
			end

			local Scroll = N("ScrollingFrame",{
				Size=UDim2.new(1,-16,0,math.min(#list,5)*27),
				Position=UDim2.fromOffset(8,cYOff),
				BackgroundTransparency=1,
				ScrollBarThickness=2,ScrollBarImageColor3=C.BORDER,
				CanvasSize=UDim2.new(0,0,0,#list*27),Parent=fr,
			})
			local DHL
			if not isMulti then
				DHL=N("Frame",{
					Size=UDim2.new(1,0,0,25),BackgroundColor3=ACCENT,BackgroundTransparency=0.88,
					Visible=false,ZIndex=1,Parent=Scroll,
				})
				Corner(6,DHL)
			end
			local OptH=N("Frame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,ZIndex=2,Parent=Scroll})
			N("UIListLayout",{Padding=UDim.new(0,1),SortOrder=Enum.SortOrder.LayoutOrder,Parent=OptH})

			local function UpdTitle()
				if isMulti then
					local sl={} for k in pairs(selected) do table.insert(sl,k) end
					dtitle.Text=#sl==0 and text or (#sl==1 and sl[1] or sl[1].." (+"..(#sl-1)..")")
				else dtitle.Text=selected or text end
			end

			local function Sel(v,btn)
				if isMulti then
					if selected[v] then selected[v]=nil TweenService:Create(btn,FAST,{TextColor3=C.TEXT_DIM}):Play()
					else selected[v]=true TweenService:Create(btn,FAST,{TextColor3=C.TEXT}):Play() end
					local sl={} for k in pairs(selected) do table.insert(sl,k) end
					Library.Flags[flag]=sl UpdTitle() cb(sl)
				else
					selected=v
					if DHL then
						DHL.Visible=true
						local ty=(btn.AbsolutePosition.Y-Scroll.AbsolutePosition.Y)+Scroll.CanvasPosition.Y
						TweenService:Create(DHL,TweenInfo.new(0.2,Enum.EasingStyle.Quart),{Position=UDim2.fromOffset(0,ty)}):Play()
					end
					for _,o in pairs(OptH:GetChildren()) do
						if o:IsA("TextButton") then TweenService:Create(o,FAST,{TextColor3=C.TEXT_DIM}):Play() end
					end
					TweenService:Create(btn,FAST,{TextColor3=C.TEXT}):Play()
					Library.Flags[flag]=v UpdTitle() cb(v)
				end
			end

			for i,v in ipairs(list) do
				local opt=N("TextButton",{
					Text=v,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TEXT_DIM,
					Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=i,Parent=OptH,
				})
				opt.MouseButton1Click:Connect(function() Sel(v,opt) end)
				if isMulti and selected[v] then opt.TextColor3=C.TEXT end
				if not isMulti and default and v==default then
					task.spawn(function()
						repeat task.wait() until opt.AbsolutePosition.Y>0
						Sel(v,opt)
					end)
				end
			end

			if isSearch then
				SBar:GetPropertyChangedSignal("Text"):Connect(function()
					local q=SBar.Text:lower()
					local cnt=0
					for _,b in pairs(OptH:GetChildren()) do
						if b:IsA("TextButton") then
							local vis=b.Text:lower():find(q)~=nil
							b.Visible=vis if vis then cnt=cnt+1 end
						end
					end
					Scroll.CanvasSize=UDim2.new(0,0,0,cnt*27)
					local ch=math.min(cnt,5)*27
					Scroll.Size=UDim2.new(1,-16,0,ch)
					if expanded then fr.Size=UDim2.new(1,0,0,cYOff+ch+8) end
				end)
			end

			hdr.MouseButton1Click:Connect(function()
				expanded=not expanded
				local cnt=0
				for _,b in pairs(OptH:GetChildren()) do
					if b:IsA("TextButton") and b.Visible then cnt=cnt+1 end
				end
				local ch=math.min(cnt,5)*27
				Scroll.CanvasSize=UDim2.new(0,0,0,cnt*27)
				Scroll.Size=UDim2.new(1,-16,0,ch)
				TweenService:Create(fr,SMOOTH,{Size=UDim2.new(1,0,0,expanded and (cYOff+ch+8) or 34)}):Play()
				TweenService:Create(arr,SMOOTH,{Rotation=expanded and 270 or 90}):Play()
			end)
			Hover(hdr,fr,C.CARD,C.CARD_HOV)

			local F={}
			function F:Set(val)
				if isMulti then
					selected={}
					if val and type(val)=="table" then for _,v in ipairs(val) do selected[v]=true end end
					for _,btn in pairs(OptH:GetChildren()) do
						if btn:IsA("TextButton") then
							TweenService:Create(btn,FAST,{TextColor3=selected[btn.Text] and C.TEXT or C.TEXT_DIM}):Play()
						end
					end
					local sl={} for k in pairs(selected) do table.insert(sl,k) end
					Library.Flags[flag]=sl UpdTitle() cb(sl)
				else
					selected=val Library.Flags[flag]=val
					for _,btn in pairs(OptH:GetChildren()) do
						if btn:IsA("TextButton") then
							TweenService:Create(btn,FAST,{TextColor3=btn.Text==val and C.TEXT or C.TEXT_DIM}):Play()
						end
					end
					UpdTitle() cb(val)
				end
			end
			function F:Refresh(newList)
				list=newList
				for _,c in pairs(OptH:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
				for i,v in ipairs(list) do
					local opt=N("TextButton",{
						Text=v,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TEXT_DIM,
						Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=i,Parent=OptH,
					})
					opt.MouseButton1Click:Connect(function() Sel(v,opt) end)
					if isMulti and selected[v] then opt.TextColor3=C.TEXT
					elseif not isMulti and selected==v then opt.TextColor3=C.TEXT end
				end
				Scroll.CanvasSize=UDim2.new(0,0,0,#list*27)
				if expanded then
					local ch=math.min(#list,5)*27
					Scroll.Size=UDim2.new(1,-16,0,ch)
					fr.Size=UDim2.new(1,0,0,cYOff+ch+8)
				end
			end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			Library.Items[flag]=F
			RegSearch(text, "dropdown", F, flag)
			return F
		end

		function Tab:Label(cfg2)
			local fr=N("Frame",{Size=UDim2.new(1,0,0,24),BackgroundColor3=C.CARD,BackgroundTransparency=0.5,Parent=Tab._Page})
			Corner(7,fr)
			local txt=N("TextLabel",{
				Font=Enum.Font.Gotham,Text=cfg2.Text or "Label",TextSize=11,
				TextColor3=C.TEXT_DIM,BackgroundTransparency=1,
				Position=UDim2.fromOffset(10,0),Size=UDim2.new(1,-20,1,0),
				TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=fr,
			})
			local function Rsz()
				local ts=TextService:GetTextSize(txt.Text,11,Enum.Font.Gotham,Vector2.new(txt.AbsoluteSize.X,9999))
				fr.Size=UDim2.new(1,0,0,ts.Y+10) txt.Size=UDim2.new(1,-20,0,ts.Y)
			end
			txt:GetPropertyChangedSignal("AbsoluteSize"):Connect(Rsz) task.spawn(Rsz)
			local F={}
			function F:Set(t) txt.Text=t task.spawn(Rsz) end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			return F
		end

		function Tab:Paragraph(cfg2)
			local title=cfg2.Title or "Title"
			local content=cfg2.Content or ""
			local fr=N("Frame",{Size=UDim2.new(1,0,0,52),BackgroundColor3=C.CARD,Parent=Tab._Page})
			Corner(8,fr)
			local tlbl=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=title:upper(),TextSize=9,
				TextColor3=C.TEXT_DIM,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,8),Size=UDim2.new(1,-24,0,12),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=fr,
			})
			N("Frame",{Size=UDim2.new(1,-24,0,1),Position=UDim2.fromOffset(12,23),
				BackgroundColor3=C.BORDER,BorderSizePixel=0,Parent=fr})
			local clbl=N("TextLabel",{
				Font=Enum.Font.Gotham,Text=content,TextSize=11,
				TextColor3=C.TEXT_DIM,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,28),Size=UDim2.new(1,-24,0,0),
				TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,
				TextWrapped=true,Parent=fr,
			})
			local function Rsz()
				local ts=TextService:GetTextSize(clbl.Text,11,Enum.Font.Gotham,Vector2.new(clbl.AbsoluteSize.X,9999))
				fr.Size=UDim2.new(1,0,0,ts.Y+40) clbl.Size=UDim2.new(1,-24,0,ts.Y)
			end
			clbl:GetPropertyChangedSignal("AbsoluteSize"):Connect(Rsz) task.spawn(Rsz)
			local F={}
			function F:Set(t,c)
				if t then tlbl.Text=t:upper() end
				if c then clbl.Text=c task.spawn(Rsz) end
			end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			return F
		end

		function Tab:Keybind(cfg2)
			local text=cfg2.Name or "Keybind"
			local default=cfg2.Default or Enum.KeyCode.RightShift
			local cb=cfg2.Callback or function() end
			local onChange=cfg2.OnChange or function() end
			local listening=false
			local fr=MakeCard(34,Tab._Page)
			N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-88,1,0),Parent=fr,
			})
			local Disp=N("Frame",{
				Size=UDim2.fromOffset(66,22),AnchorPoint=Vector2.new(1,0.5),
				Position=UDim2.new(1,-8,0.5,0),BackgroundColor3=C.INPUT,Parent=fr,
			})
			Corner(6,Disp) Stroke(C.BORDER_LT,1,Disp)
			local DText=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=default.Name,TextSize=10,
				TextColor3=C.TEXT,BackgroundTransparency=1,Size=UDim2.fromScale(1,1),Parent=Disp,
			})
			local hit=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.fromScale(1,1),ZIndex=5,Parent=fr})
			hit.MouseButton1Click:Connect(function()
				listening=true DText.Text="···"
			end)
			UIS.InputBegan:Connect(function(i,gpe)
				if gpe then return end
				if listening and i.UserInputType==Enum.UserInputType.Keyboard then
					listening=false default=i.KeyCode DText.Text=i.KeyCode.Name onChange(i.KeyCode)
				elseif not listening and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==default then
					cb()
				end
			end)
			RegSearch(text, "keybind", nil, nil)
			local F={} function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			return F
		end

		function Tab:Textbox(cfg2)
			local text=cfg2.Name or "Textbox"
			local ph=cfg2.Placeholder or "Enter..."
			local cb=cfg2.Callback or function() end
			local flag=cfg2.Flag or text
			local def=Library.Flags[flag] or ""
			local fr=MakeCard(34,Tab._Page)
			local lbl=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-80,1,0),Parent=fr,
			})
			local IH=N("Frame",{
				Size=UDim2.fromOffset(58,22),AnchorPoint=Vector2.new(1,0.5),
				Position=UDim2.new(1,-8,0.5,0),BackgroundColor3=C.INPUT,ClipsDescendants=true,Parent=fr,
			})
			Corner(6,IH) Stroke(C.BORDER_LT,1,IH)
			local Inp=N("TextBox",{
				Text=def,PlaceholderText=ph,Font=Enum.Font.Gotham,TextSize=10,
				TextColor3=C.TEXT,BackgroundTransparency=1,
				Size=UDim2.new(1,-8,1,0),Position=UDim2.fromOffset(4,0),
				TextXAlignment=Enum.TextXAlignment.Center,Parent=IH,
			})
			Inp.Focused:Connect(function()
				TweenService:Create(IH,SMOOTH,{Size=UDim2.fromOffset(165,22),Position=UDim2.new(1,-173,0.5,0)}):Play()
				TweenService:Create(lbl,FAST,{TextTransparency=0.5}):Play()
			end)
			Inp.FocusLost:Connect(function(enter)
				TweenService:Create(IH,SMOOTH,{Size=UDim2.fromOffset(58,22),Position=UDim2.new(1,-8,0.5,0)}):Play()
				TweenService:Create(lbl,FAST,{TextTransparency=0}):Play()
				Library.Flags[flag]=Inp.Text cb(Inp.Text,enter)
			end)
			RegSearch(text, "textbox", nil, flag)
			local F={}
			function F:Set(v) Inp.Text=v Library.Flags[flag]=v cb(v,false) end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			Library.Items[flag]=F
			return F
		end

		function Tab:NewSection(name, open)
			local Section={}
			local expanded=open or false
			local SBg=N("Frame",{
				Size=UDim2.new(1,0,0,28),BackgroundColor3=C.CARD,
				ClipsDescendants=true,Parent=Tab._Page,
			})
			Corner(8,SBg)
			local SHdr=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,0,28),Parent=SBg})
			N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=name,TextSize=11,TextColor3=C.TEXT_DIM,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-36,1,0),Parent=SHdr,
			})
			local arrLbl=N("TextLabel",{
				Text="›",Font=Enum.Font.GothamBold,TextSize=14,TextColor3=C.TEXT_MUT,
				BackgroundTransparency=1,Rotation=expanded and 90 or 0,
				AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
				Size=UDim2.fromOffset(18,18),Parent=SHdr,
			})
			local SCont=N("Frame",{
				Size=UDim2.new(1,-10,0,0),Position=UDim2.fromOffset(5,28),
				BackgroundTransparency=1,Parent=SBg,
			})
			local SLL=N("UIListLayout",{Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder,Parent=SCont})
			local function UpdSec()
				local h=SLL.AbsoluteContentSize.Y
				SCont.Size=UDim2.new(1,-10,0,h)
				TweenService:Create(SBg,SMOOTH,{Size=UDim2.new(1,0,0,expanded and h+36 or 28)}):Play()
			end
			if expanded then task.delay(0.1,UpdSec) end
			SLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdSec)
			SHdr.MouseButton1Click:Connect(function()
				expanded=not expanded
				TweenService:Create(arrLbl,FAST,{Rotation=expanded and 90 or 0}):Play()
				UpdSec()
			end)

			local function SCard(h)
				local f=N("Frame",{Size=UDim2.new(1,0,0,h),BackgroundColor3=C.CARD_HOV,Parent=SCont})
				Corner(7,f) return f
			end

			function Section:Button(cfg2)
				local text=cfg2.Name or cfg2.Text or "Button"
				local cb=cfg2.Callback or function() end
				local fr=SCard(34)
				local btn=N("TextButton",{
					Font=Enum.Font.GothamBold,Text=text,TextSize=11,TextColor3=C.TEXT,
					BackgroundColor3=C.BTN,AutoButtonColor=false,BorderSizePixel=0,
					Size=UDim2.new(1,-8,0,26),Position=UDim2.fromOffset(4,4),Parent=fr,
				})
				Corner(6,btn) Hover(btn,btn,C.BTN,C.BTN_HOV) Press(btn,btn,C.BTN,Color3.fromRGB(48,50,62))
				btn.MouseButton1Click:Connect(cb)
				RegSearch(text,"button",nil,nil)
				local F={} function F:Hide() fr.Visible=false UpdSec() end function F:Show() fr.Visible=true UpdSec() end
				return F
			end
			function Section:DualButton(c1,c2)
				local fr=N("Frame",{Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,Parent=SCont})
				N("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,5),Parent=fr})
				local function Half(cfg2)
					local text=cfg2.Name or cfg2.Text or "Button"
					local cb=cfg2.Callback or function() end
					local bg=N("Frame",{Size=UDim2.new(0.5,-3,1,0),BackgroundColor3=C.CARD_HOV,Parent=fr})
					Corner(7,bg)
					local btn=N("TextButton",{
						Font=Enum.Font.GothamBold,Text=text,TextSize=11,TextColor3=C.TEXT,
						BackgroundColor3=C.BTN,AutoButtonColor=false,BorderSizePixel=0,
						Size=UDim2.new(1,-8,0,26),Position=UDim2.fromOffset(4,4),Parent=bg,
					})
					Corner(6,btn) Hover(btn,btn,C.BTN,C.BTN_HOV) Press(btn,btn,C.BTN,Color3.fromRGB(48,50,62))
					btn.MouseButton1Click:Connect(cb)
					RegSearch(text,"button",nil,nil)
				end
				Half(c1) Half(c2)
				return {Hide=function() fr.Visible=false UpdSec() end, Show=function() fr.Visible=true UpdSec() end}
			end
			function Section:Toggle(cfg2)
				local text=cfg2.Name or "Toggle"
				local cb=cfg2.Callback or function() end
				local flag=cfg2.Flag or text
				local state=cfg2.Default or false
				if Library.Flags[flag]~=nil then state=Library.Flags[flag] end
				Library.Flags[flag]=state
				local fr=SCard(34)
				N("TextLabel",{
					Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
					TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
					Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-62,1,0),Parent=fr,
				})
				local hit=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.fromScale(1,1),ZIndex=5,Parent=fr})
				local sw=N("Frame",{
					AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
					Size=UDim2.fromOffset(32,16),BackgroundColor3=state and ACCENT or C.SW_OFF,BorderSizePixel=0,Parent=fr,
				})
				Corner(16,sw)
				local knob=N("Frame",{
					Size=UDim2.fromOffset(12,12),
					Position=state and UDim2.fromOffset(18,2) or UDim2.fromOffset(2,2),
					BackgroundColor3=state and C.WHITE or C.SW_KNOB,BorderSizePixel=0,Parent=sw,
				})
				Corner(16,knob)
				local function updSw(v)
					TweenService:Create(sw,FAST,{BackgroundColor3=v and ACCENT or C.SW_OFF}):Play()
					TweenService:Create(knob,FAST,{
						Position=v and UDim2.fromOffset(18,2) or UDim2.fromOffset(2,2),
						BackgroundColor3=v and C.WHITE or C.SW_KNOB,
					}):Play()
				end
				hit.MouseButton1Click:Connect(function()
					state=not state Library.Flags[flag]=state updSw(state) cb(state)
				end)
				Hover(hit,fr,C.CARD_HOV,C.CARD)
				local F={}
				function F:Set(v) state=v Library.Flags[flag]=v updSw(v) cb(v) end
				function F:Hide() fr.Visible=false UpdSec() end function F:Show() fr.Visible=true UpdSec() end
				Library.Items[flag]=F
				RegSearch(text,"toggle",F,flag)
				return F
			end
			function Section:Slider(cfg2) return Tab:Slider(cfg2) end
			function Section:Dropdown(cfg2) return Tab:Dropdown(cfg2) end
			function Section:Textbox(cfg2) return Tab:Textbox(cfg2) end
			function Section:Label(cfg2) return Tab:Label(cfg2) end
			function Section:Paragraph(cfg2) return Tab:Paragraph(cfg2) end
			return Section
		end

		return Tab
	end

	task.spawn(function()
		local ad=self:GetAutoLoad()
		if ad.AutoLoadEnabled and ad.AutoLoadName~="" then
			task.wait(0.5) self:LoadConfig(ad.AutoLoadName)
		end
	end)

	return self
end

return Library
