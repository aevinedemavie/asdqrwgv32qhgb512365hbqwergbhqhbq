					Size = UDim2.new(1, -12, 1, -12), Position = UDim2.fromOffset(6, 6),
					BackgroundColor3 = C.ELEM, Parent = Bg,
				}, {Create("UICorner", {CornerRadius = UDim.new(0, 6)})})
				Stroke(Inner, C.CHROME_DIM, 1, 0.68)
				local Lbl = Create("TextLabel", {
					Text = text, Font = Enum.Font.GothamMedium, TextSize = 12,
					TextColor3 = C.TXT_HI, BackgroundTransparency = 1,
					Size = UDim2.fromScale(1, 1), TextXAlignment = "Center", Parent = Inner,
				})
				local Hit = Create("TextButton", {Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ZIndex = 5, Parent = Bg})
				Hit.MouseButton1Down:Connect(function()
					TweenService:Create(Inner, TweenInfo.new(0.11), {BackgroundColor3 = C.ELEM_HOV}):Play()
					TweenService:Create(Lbl, TweenInfo.new(0.11), {TextColor3 = C.CHROME_GLOW}):Play()
				end)
				Hit.MouseButton1Up:Connect(function()
					TweenService:Create(Inner, TweenInfo.new(0.2), {BackgroundColor3 = C.ELEM}):Play()
					TweenService:Create(Lbl, TweenInfo.new(0.2), {TextColor3 = C.TXT_HI}):Play()
					cb()
				end)
				local F = {}
				function F:Hide() Bg.Visible = false UpdSec() end function F:Show() Bg.Visible = true UpdSec() end
				return F
			end

			function Section:Button(cfg2) return SBtn(cfg2, SCont) end

			function Section:DualButton(c1, c2)
				local Row = Create("Frame", {Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1, Parent = SCont},
					{Create("UIListLayout", {FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 6)})})
				local function SHalf(cfg2)
					local Bg = Create("Frame", {
						Size = UDim2.new(0.5, -3, 1, 0),
						BackgroundColor3 = C.GLASS, Parent = Row,
					}, {Create("UICorner", {CornerRadius = UDim.new(0, 8)})})
					Stroke(Bg, C.CHROME_DIM, 1, 0.55)
					Acrylic(Bg, 8, 0.93)
					local Inner = Create("Frame", {
						Size = UDim2.new(1, -12, 1, -12), Position = UDim2.fromOffset(6, 6),
						BackgroundColor3 = C.ELEM, Parent = Bg,
					}, {Create("UICorner", {CornerRadius = UDim.new(0, 6)})})
					Stroke(Inner, C.CHROME_DIM, 1, 0.68)
					local Lbl = Create("TextLabel", {
						Text = cfg2.Name or "Button", Font = Enum.Font.GothamMedium, TextSize = 11,
						TextColor3 = C.TXT_HI, BackgroundTransparency = 1,
						Size = UDim2.fromScale(1, 1), TextXAlignment = "Center", Parent = Inner,
					})
					local Hit = Create("TextButton", {Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ZIndex = 5, Parent = Bg})
					Hit.MouseButton1Down:Connect(function()
						TweenService:Create(Inner, TweenInfo.new(0.11), {BackgroundColor3 = C.ELEM_HOV}):Play()
						TweenService:Create(Lbl, TweenInfo.new(0.11), {TextColor3 = C.CHROME_GLOW}):Play()
					end)
					Hit.MouseButton1Up:Connect(function()
						TweenService:Create(Inner, TweenInfo.new(0.2), {BackgroundColor3 = C.ELEM}):Play()
						TweenService:Create(Lbl, TweenInfo.new(0.2), {TextColor3 = C.TXT_HI}):Play()
						if cfg2.Callback then cfg2.Callback() end
					end)
				end
				SHalf(c1) SHalf(c2)
				return {Hide = function() Row.Visible = false UpdSec() end, Show = function() Row.Visible = true UpdSec() end}
			end

			function Section:Toggle(cfg2)
				local text  = cfg2.Name or "Toggle"
				local cb    = cfg2.Callback or function() end
				local flag  = cfg2.Flag or text
				local state = cfg2.Default or false
				if Library.Flags[flag] ~= nil then state = Library.Flags[flag] end
				Library.Flags[flag] = state
				local Bg = Create("Frame", {
					Size = UDim2.new(1, 0, 0, 40),
					BackgroundColor3 = C.GLASS, Parent = SCont,
				}, {Create("UICorner", {CornerRadius = UDim.new(0, 8)})})
				Stroke(Bg, C.CHROME_DIM, 1, 0.55)
				Acrylic(Bg, 8, 0.93)
				Create("TextLabel", {
					Text = text, Font = Enum.Font.GothamMedium, TextSize = 12,
					TextColor3 = C.TXT_HI, BackgroundTransparency = 1,
					Position = UDim2.fromOffset(13, 0), Size = UDim2.new(1, -65, 1, 0),
					TextXAlignment = "Left", Parent = Bg,
				})
				local Sw = Create("Frame", {
					Size = UDim2.fromOffset(36, 17), Position = UDim2.new(1, -46, 0.5, -9),
					BackgroundColor3 = state and C.CHROME or C.FILL, Parent = Bg,
				}, {Create("UICorner", {CornerRadius = UDim.new(1, 0)})})
				Stroke(Sw, C.CHROME_DIM, 1, 0.5)
				local Knob = Create("Frame", {
					Size = UDim2.fromOffset(13, 13),
					Position = state and UDim2.fromOffset(21, 2) or UDim2.fromOffset(2, 2),
					BackgroundColor3 = state and C.BASE or C.TXT_LOW, Parent = Sw,
				}, {Create("UICorner", {CornerRadius = UDim.new(1, 0)})})
				local function updSw(v)
					TweenService:Create(Sw, TweenInfo.new(0.17), {BackgroundColor3 = v and C.CHROME or C.FILL}):Play()
					TweenService:Create(Knob, TweenInfo.new(0.17), {
						Position = v and UDim2.fromOffset(21, 2) or UDim2.fromOffset(2, 2),
						BackgroundColor3 = v and C.BASE or C.TXT_LOW,
					}):Play()
				end
				local Hit = Create("TextButton", {Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ZIndex = 5, Parent = Bg})
				Hit.MouseButton1Click:Connect(function()
					state = not state Library.Flags[flag] = state updSw(state) cb(state)
				end)
				local F = {}
				function F:Set(v) state = v Library.Flags[flag] = v updSw(v) cb(v) end
				function F:Hide() Bg.Visible = false UpdSec() end function F:Show() Bg.Visible = true UpdSec() end
				Library.Items[flag] = F
				return F
			end

			function Section:Slider(cfg2) return Tab:Slider(cfg2) end
			function Section:Dropdown(cfg2) return Tab:Dropdown(cfg2) end
			function Section:Textbox(cfg2) return Tab:Textbox(cfg2) end
			function Section:Label(cfg2) return Tab:Label(cfg2) end
			function Section:Paragraph(cfg2) return Tab:Paragraph(cfg2) end

			return Section
		end

		return Tab
	end

	task.spawn(function()
		local ad = self:GetAutoLoad()
		if ad.AutoLoadEnabled and ad.AutoLoadName ~= "" then
			task.wait(0.5) self:LoadConfig(ad.AutoLoadName)
		end
	end)

	return self
end

return Library
