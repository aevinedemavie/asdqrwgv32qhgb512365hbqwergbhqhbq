					local opt=N("TextButton",{Text=v,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TEXT_DIM,
						Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=i,Parent=OptH})
