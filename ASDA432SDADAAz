local function Create(class, props, children)
	local obj = Instance.new(class)
	for k, v in pairs(props or {}) do obj[k] = v end
	for _, c in pairs(children or {}) do c.Parent = obj end
	return obj
end

local function Acrylic(parent, radius, alpha)
	alpha = alpha or 0.93
	local f = Create("Frame", {
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = C.WHITE,
		BackgroundTransparency = alpha,
		ZIndex = parent.ZIndex or 1,
		Parent = parent,
	})
	if radius then Create("UICorner", {CornerRadius = UDim.new(0, radius), Parent = f}) end
	local shine = Create("Frame", {
		Size = UDim2.new(1, 0, 0, 1),
		BackgroundColor3 = C.WHITE,
		BackgroundTransparency = 0.72,
		ZIndex = parent.ZIndex or 1,
		Parent = parent,
	})
	if radius then Create("UICorner", {CornerRadius = UDim.new(0, radius), Parent = shine}) end
end

local function Stroke(parent, col, thick, alpha)
	return Create("UIStroke", {
		Color = col or C.CHROME_DIM,
		Thickness = thick or 1,
		Transparency = alpha or 0.5,
		Parent = parent,
	})
end

local Library = {}
Library.__index = Library
Library.Flags     = {}
Library.Items     = {}
Library.ToggleKey = Enum.KeyCode.RightShift

function Library:GetConfigFolder()
	local path = "ObsidiaHub/Configs/" .. tostring(game.GameId)
	if not isfolder("ObsidiaHub") then makefolder("ObsidiaHub") end
	if not isfolder("ObsidiaHub/Configs") then makefolder("ObsidiaHub/Configs") end
	if not isfolder(path) then makefolder(path) end
	return path
end
function Library:SaveConfig(name)
	writefile(self:GetConfigFolder() .. "/" .. name .. ".json", HttpService:JSONEncode(self.Flags))
	self:Notify({Title = "Saved", Content = "Config '" .. name .. "' saved.", Time = 3})
end
function Library:LoadConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok then
			for flag, val in pairs(dec) do
				if self.Items[flag] then pcall(function() self.Items[flag]:Set(val) end) end
			end
			self:Notify({Title = "Loaded", Content = "Config '" .. name .. "' loaded.", Time = 3})
		else
			self:Notify({Title = "Error", Content = "Failed to decode config.", Time = 3})
		end
	else
		self:Notify({Title = "Error", Content = "Config not found.", Time = 3})
	end
end
function Library:DeleteConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		delfile(path)
		self:Notify({Title = "Deleted", Content = "Config '" .. name .. "' deleted.", Time = 3})
	end
end
function Library:GetConfigs()
	local files = listfiles(self:GetConfigFolder())
	local out = {}
	for _, f in ipairs(files) do
		local n = f:match("([^/\\]+)%.json$")
		if n and n ~= "settings" then table.insert(out, n) end
	end
	return out
end
function Library:ExportConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok and setclipboard then
			setclipboard(HttpService:JSONEncode({Name = name, Data = dec}))
			self:Notify({Title = "Exported", Content = "Copied to clipboard.", Time = 3})
		end
	else
		self:Notify({Title = "Error", Content = "Config not found.", Time = 3})
	end
end
function Library:ImportConfig(str)
	if not str or str == "" then
		self:Notify({Title = "Error", Content = "Paste config data first.", Time = 3})
		return false
	end
	local ok, dec = pcall(HttpService.JSONDecode, HttpService, str)
	if ok and dec.Name and dec.Data then
		local newName = dec.Name .. " (Imported)"
		writefile(self:GetConfigFolder() .. "/" .. newName .. ".json", HttpService:JSONEncode(dec.Data))
		self:Notify({Title = "Imported", Content = "'" .. newName .. "' created.", Time = 3})
		return true
	else
		self:Notify({Title = "Error", Content = "Invalid config format.", Time = 3})
		return false
	end
end
function Library:SetAutoLoad(name, enabled)
	writefile(self:GetConfigFolder() .. "/settings.json",
		HttpService:JSONEncode({AutoLoadName = name or "", AutoLoadEnabled = enabled or false}))
end
function Library:GetAutoLoad()
	local path = self:GetConfigFolder() .. "/settings.json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok then return dec end
	end
	return {AutoLoadName = "", AutoLoadEnabled = false}
end

function Library:ConfigManager(section)
	section:Paragraph({Title = "Configuration", Content = "Save, load, and share your configurations."})
	local configName = ""
	local nameInput, configList
	nameInput = section:Textbox({Name = "Config Name", Placeholder = "Enter name...", Callback = function(v) configName = v end})
	configList = section:Dropdown({Name = "Config List", List = self:GetConfigs(), Callback = function(v)
		configName = v
		if nameInput then nameInput:Set(v) end
	end})
	section:DualButton(
		{Name = "Save", Callback = function()
			if configName ~= "" then self:SaveConfig(configName) configList:Refresh(self:GetConfigs())
			else self:Notify({Title = "Error", Content = "Enter a name.", Time = 3}) end
		end},
		{Name = "Load", Callback = function()
			if configName ~= "" then self:LoadConfig(configName)
			else self:Notify({Title = "Error", Content = "Select a config.", Time = 3}) end
		end}
	)
	section:DualButton(
		{Name = "Overwrite", Callback = function()
			if configName ~= "" then self:SaveConfig(configName)
			else self:Notify({Title = "Error", Content = "Select a config.", Time = 3}) end
		end},
		{Name = "Refresh", Callback = function() configList:Refresh(self:GetConfigs()) end}
	)
	section:Button({Name = "Delete Config", Callback = function()
		if configName ~= "" then
			self:DeleteConfig(configName) configList:Refresh(self:GetConfigs())
			configName = ""
			if nameInput then nameInput:Set("") end
		else self:Notify({Title = "Error", Content = "Select a config.", Time = 3}) end
	end})
	section:Paragraph({Title = "Share", Content = "Export to clipboard or import from JSON string."})
	section:Button({Name = "Export Config", Callback = function()
		if configName ~= "" then self:ExportConfig(configName)
		else self:Notify({Title = "Error", Content = "Select a config.", Time = 3}) end
	end})
	local importStr = ""
	section:Textbox({Name = "Import Data", Placeholder = "Paste JSON...", Callback = function(v) importStr = v end})
	section:Button({Name = "Import Config", Callback = function()
		if self:ImportConfig(importStr) then configList:Refresh(self:GetConfigs()) end
	end})
	section:Paragraph({Title = "Auto-Load", Content = "Automatically load a config on script start."})
	local autoData = self:GetAutoLoad()
	local autoLabel = section:Label({Text = "Auto-Load: " .. (autoData.AutoLoadName ~= "" and autoData.AutoLoadName or "None")})
	section:Toggle({Name = "Enable Auto-Load", Default = autoData.AutoLoadEnabled, NoSave = true, Callback = function(v)
		local d = self:GetAutoLoad() self:SetAutoLoad(d.AutoLoadName, v)
	end})
	section:Button({Name = "Set as Auto-Load", Callback = function()
		if configName ~= "" then
			local d = self:GetAutoLoad() self:SetAutoLoad(configName, d.AutoLoadEnabled)
			autoLabel:Set("Auto-Load: " .. configName)
			self:Notify({Title = "Set", Content = "'" .. configName .. "' is now auto-load.", Time = 3})
		else self:Notify({Title = "Error", Content = "Select a config first.", Time = 3}) end
	end})
end

function Library.SettingManager()
	local M = {}
	function M:AddToTab(tab)
		tab:Paragraph({Title = "UI Settings", Content = "Keybind and interface controls."})
		tab:Keybind({Name = "Toggle Key", Default = Library.ToggleKey, OnChange = function(k) Library.ToggleKey = k end})
