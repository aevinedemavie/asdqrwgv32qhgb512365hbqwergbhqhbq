						end
					end
					local sl = {} for k in pairs(selected) do table.insert(sl, k) end
					Library.Flags[flag] = sl UpdTitle() cb(sl)
				else
					selected = val Library.Flags[flag] = val
					for _, btn in pairs(OptH:GetChildren()) do
						if btn:IsA("TextButton") then
							TweenService:Create(btn, TweenInfo.new(0.14), {TextColor3 = btn.Text == val and C.TXT_HI or C.TXT_MID}):Play()
						end
					end
					UpdTitle() cb(val)
				end
			end
			function F:Refresh(newList)
				list = newList
