local function N(class, props, parent)
	local o = Instance.new(class)
	for k, v in pairs(props or {}) do o[k] = v end
	if parent then o.Parent = parent end
	return o
end

local function Corner(r, p) return N("UICorner", {CornerRadius = UDim.new(0, r)}, p) end
local function Stroke(col, thick, p) return N("UIStroke", {Color = col or C.BORDER, Thickness = thick or 1, Parent = p}) end
local function Pad(p, l, r, t, b) return N("UIPadding", {PaddingLeft=UDim.new(0,l or 0), PaddingRight=UDim.new(0,r or 0), PaddingTop=UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or 0)}, p) end

local function Hover(btn, frame, norm, hov)
	btn.MouseEnter:Connect(function() TweenService:Create(frame, FAST, {BackgroundColor3 = hov}):Play() end)
	btn.MouseLeave:Connect(function() TweenService:Create(frame, FAST, {BackgroundColor3 = norm}):Play() end)
end

local function Press(btn, frame, norm, press)
	btn.MouseButton1Down:Connect(function() TweenService:Create(frame, FAST, {BackgroundColor3 = press}):Play() end)
	btn.MouseButton1Up:Connect(function()   TweenService:Create(frame, FAST, {BackgroundColor3 = norm}):Play() end)
	btn.MouseLeave:Connect(function()       TweenService:Create(frame, FAST, {BackgroundColor3 = norm}):Play() end)
end

local function Draggable(handle, frame)
	local drag, dStart, dPos
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			drag = true dStart = i.Position dPos = frame.Position
			i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			local d = i.Position - dStart
			TweenService:Create(frame, TweenInfo.new(0.04), {
				Position = UDim2.new(dPos.X.Scale, dPos.X.Offset + d.X, dPos.Y.Scale, dPos.Y.Offset + d.Y)
			}):Play()
		end
	end)
end

local function MakeResizable(frame, minW, minH, maxW, maxH)
	local handle = N("Frame", {
		Name = "ResizeHandle",
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.fromScale(1, 1),
		Size = UDim2.fromOffset(18, 18),
		BackgroundTransparency = 1,
		ZIndex = 20,
		Parent = frame,
	})
	for _, dot in ipairs({{14,14},{10,14},{14,10}}) do
		local d = N("Frame", {
			Size = UDim2.fromOffset(3, 3),
			Position = UDim2.fromOffset(dot[1], dot[2]),
			BackgroundColor3 = C.BORDER_LT,
			BorderSizePixel = 0,
			ZIndex = 21,
			Parent = handle,
		})
		Corner(2, d)
	end
	local resizing, rStart, rSize = false, nil, nil
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			resizing = true rStart = i.Position rSize = frame.Size
			i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then resizing = false end end)
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if resizing and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			local d = i.Position - rStart
			local nw = math.clamp(rSize.X.Offset + d.X, minW, maxW)
			local nh = math.clamp(rSize.Y.Offset + d.Y, minH, maxH)
			TweenService:Create(frame, TweenInfo.new(0.04), {Size = UDim2.fromOffset(nw, nh)}):Play()
		end
	end)
end

local function SmartMatch(query, target)
	if query == "" then return 0 end
	local q, t = query:lower(), target:lower()
	if q == t then return 1000 end
	if t:sub(1, #q) == q then return 800 end
	local idx = t:find(q, 1, true)
	if idx then return 600 - idx end
	local qi, ti, lastIdx = 1, 1, 0
	while qi <= #q and ti <= #t do
		if q:sub(qi, qi) == t:sub(ti, ti) then
			lastIdx = ti
			qi = qi + 1
		end
		ti = ti + 1
	end
	if qi > #q then
		return 200 - (lastIdx - #q) * 2
	end
	return 0
end

