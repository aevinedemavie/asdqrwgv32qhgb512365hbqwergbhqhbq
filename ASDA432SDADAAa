					local count = 0 local first = nil
					for k in pairs(selected) do count = count + 1 if not first then first = k end end
					if count == 0 then subtitle.Text = "None selected"
					elseif count == 1 then subtitle.Text = tostring(first)
					else subtitle.Text = count .. " selected" end
				else
