			local OptH=N("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,ZIndex=2,Parent=Scroll})
			N("UIListLayout",{Padding=UDim.new(0,2),SortOrder=Enum.SortOrder.LayoutOrder,Parent=OptH})

			local optionButtons = {}

			local function refreshVisualState()
				for v, btn in pairs(optionButtons) do
					local isSel = isMulti and selected[v] or (not isMulti and selected == v)
					local bg = btn:FindFirstChild("BG")
					local lbl = btn:FindFirstChild("LBL")
					local check = btn:FindFirstChild("Check")
					if isSel then
						if bg then TweenService:Create(bg,FAST,{BackgroundTransparency=0.85}):Play() end
						if lbl then TweenService:Create(lbl,FAST,{TextColor3=C.TEXT}):Play() end
						if check then check.Visible = true end
					else
						if bg then TweenService:Create(bg,FAST,{BackgroundTransparency=1}):Play() end
						if lbl then TweenService:Create(lbl,FAST,{TextColor3=C.TEXT_DIM}):Play() end
						if check then check.Visible = false end
					end
				end
				updSubtitle()
