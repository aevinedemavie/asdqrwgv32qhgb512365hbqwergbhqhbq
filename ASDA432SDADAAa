					Size=UDim2.new(1,0,0,26),BackgroundColor3=C.CARD,BackgroundTransparency=0.4,BorderSizePixel=0,Parent=SCont,
				})
				Corner(7,fr)
				local txt=N("TextLabel",{
					Font=Enum.Font.Gotham,Text=cfg2.Text or "Label",TextSize=11,TextColor3=C.TEXT_DIM,
					BackgroundTransparency=1,Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-24,1,0),
					TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=fr,
				})
				local function Rsz()
					local ts=TextService:GetTextSize(txt.Text,11,Enum.Font.Gotham,Vector2.new(txt.AbsoluteSize.X,9999))
					fr.Size=UDim2.new(1,0,0,ts.Y+14) txt.Size=UDim2.new(1,-24,0,ts.Y)
				end
				txt:GetPropertyChangedSignal("AbsoluteSize"):Connect(Rsz) task.spawn(Rsz)
				local F={} function F:Set(t) txt.Text=t task.spawn(Rsz) end
				function F:Hide() fr.Visible=false UpdSec() end function F:Show() fr.Visible=true UpdSec() end return F
			end

			function Section:Paragraph(cfg2)
				return Tab:Paragraph(cfg2)
			end

			function Section:Divider(text)
				local fr=N("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Parent=SCont})
				if text then
					local tw = TextService:GetTextSize(text,10,Enum.Font.GothamBold,Vector2.new(999,999)).X
					N("TextLabel",{
						Text=text,Font=Enum.Font.GothamBold,TextSize=10,TextColor3=C.TEXT_MUT,
						BackgroundTransparency=1,Position=UDim2.fromOffset(4,2),Size=UDim2.fromOffset(tw,14),
						TextXAlignment=Enum.TextXAlignment.Left,Parent=fr,
					})
					N("Frame",{Size=UDim2.new(1,-(tw+16),0,1),Position=UDim2.fromOffset(tw+12,9),
						BackgroundColor3=C.DIVIDER,BorderSizePixel=0,Parent=fr})
				else
					N("Frame",{Size=UDim2.new(1,-8,0,1),Position=UDim2.fromOffset(4,9),
						BackgroundColor3=C.DIVIDER,BorderSizePixel=0,Parent=fr})
				end
				return {Hide=function() fr.Visible=false UpdSec() end, Show=function() fr.Visible=true UpdSec() end}
			end

			return Section
		end

		return Tab
	end

	task.defer(function() if FirstTabSwitch then FirstTabSwitch() end end)
	task.spawn(function()
		local ad=self:GetAutoLoad()
		if ad.AutoLoadEnabled and ad.AutoLoadName~="" then task.wait(0.5) self:LoadConfig(ad.AutoLoadName) end
	end)
	return self
end

return Library
