					TextXAlignment=Enum.TextXAlignment.Left,Parent=fr,
				})
				N("Frame",{Size=UDim2.new(1,-(tw+10),0,1),Position=UDim2.fromOffset(tw+8,10),
					BackgroundColor3=C.DIVIDER,BorderSizePixel=0,Parent=fr})
			else
				N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.fromOffset(0,10),
					BackgroundColor3=C.DIVIDER,BorderSizePixel=0,Parent=fr})
			end
			return {Hide=function() fr.Visible=false end, Show=function() fr.Visible=true end}
		end

		function Tab:Keybind(cfg2)
			local text=cfg2.Name or "Keybind" local default=cfg2.Default or Enum.KeyCode.RightShift
			local cb=cfg2.Callback or function() end local onChange=cfg2.OnChange or function() end
			local listening=false
			local fr=MakeCard(38,Tab._Page)
			N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12,0),Size=UDim2.new(1,-92,1,0),Parent=fr,
			})
			local Disp=N("Frame",{
				Size=UDim2.fromOffset(72,24),AnchorPoint=Vector2.new(1,0.5),
				Position=UDim2.new(1,-10,0.5,0),BackgroundColor3=C.INPUT,BorderSizePixel=0,Parent=fr,
			})
			Corner(6,Disp) Stroke(C.BORDER_LT,1,Disp)
			local DText=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=default.Name,TextSize=10,
				TextColor3=C.TEXT,BackgroundTransparency=1,Size=UDim2.fromScale(1,1),Parent=Disp,
			})
			local hit=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.fromScale(1,1),ZIndex=5,Parent=fr})
			hit.MouseButton1Click:Connect(function() listening=true DText.Text="···" TweenService:Create(Disp,FAST,{BackgroundColor3=ACCENT_DIM}):Play() end)
			UIS.InputBegan:Connect(function(i,gpe)
				if gpe then return end
				if listening and i.UserInputType==Enum.UserInputType.Keyboard then
					listening=false default=i.KeyCode DText.Text=i.KeyCode.Name
					TweenService:Create(Disp,FAST,{BackgroundColor3=C.INPUT}):Play()
					onChange(i.KeyCode)
				elseif not listening and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==default then
					cb()
				end
			end)
			RegSearch(text,"keybind",nil,nil)
			local F={} function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end return F
		end

		local function BuildTextbox(parent, cfg2)
			local text=cfg2.Name or "Textbox" local ph=cfg2.Placeholder or "Enter..."
			local cb=cfg2.Callback or function() end local flag=cfg2.Flag or text
			local def=Library.Flags[flag] or ""
			local wide = cfg2.Wide
			local fr=MakeCard(wide and 64 or 38, parent)

			local lbl=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=text,TextSize=12,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(12, wide and 6 or 0),
				Size=wide and UDim2.new(1,-24,0,16) or UDim2.new(1,-130,1,0),
				Parent=fr,
			})

			local IH
			if wide then
				IH=N("Frame",{
					Size=UDim2.new(1,-24,0,28),Position=UDim2.fromOffset(12,28),
					BackgroundColor3=C.INPUT,ClipsDescendants=true,BorderSizePixel=0,Parent=fr,
				})
			else
				IH=N("Frame",{
					Size=UDim2.fromOffset(110,24),AnchorPoint=Vector2.new(1,0.5),
					Position=UDim2.new(1,-10,0.5,0),BackgroundColor3=C.INPUT,ClipsDescendants=true,BorderSizePixel=0,Parent=fr,
				})
			end
			Corner(6,IH) Stroke(C.BORDER_LT,1,IH)
			local Inp=N("TextBox",{
				Text=def,PlaceholderText=ph,Font=Enum.Font.Gotham,TextSize=11,
				TextColor3=C.TEXT,PlaceholderColor3=C.TEXT_MUT,
				BackgroundTransparency=1,Size=UDim2.new(1,-16,1,0),Position=UDim2.fromOffset(8,0),
				TextXAlignment=Enum.TextXAlignment.Left,
				ClearTextOnFocus=false,
				Parent=IH,
			})
			Inp.Focused:Connect(function()
				TweenService:Create(IH,FAST,{BackgroundColor3=Color3.fromRGB(20,21,30)}):Play()
				IH:FindFirstChildOfClass("UIStroke").Color = ACCENT
			end)
			Inp.FocusLost:Connect(function(enter)
				TweenService:Create(IH,FAST,{BackgroundColor3=C.INPUT}):Play()
				IH:FindFirstChildOfClass("UIStroke").Color = C.BORDER_LT
				Library.Flags[flag]=Inp.Text cb(Inp.Text,enter)
			end)
			RegSearch(text,"textbox",nil,flag)
			local F={}
			function F:Set(v) Inp.Text=v Library.Flags[flag]=v cb(v,false) end
			function F:Get() return Inp.Text end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			Library.Items[flag]=F return F
		end

		function Tab:Textbox(cfg2) return BuildTextbox(Tab._Page, cfg2) end

		function Tab:NewSection(name, open)
			local Section={} local expanded=open or false
			local SBg=N("Frame",{
				Size=UDim2.new(1,0,0,36),BackgroundColor3=C.GLASS,BorderSizePixel=0,ClipsDescendants=true,Parent=Tab._Page,
			})
			Corner(8,SBg) Stroke(C.BORDER,1,SBg)

			local accentLine=N("Frame",{
				Size=UDim2.new(0,3,0,18),AnchorPoint=Vector2.new(0,0.5),
				Position=UDim2.new(0,0,0,18),BackgroundColor3=ACCENT,BorderSizePixel=0,Parent=SBg,
			})
			Corner(2,accentLine)

			local SHdr=N("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,0,36),Parent=SBg})

			N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=name,TextSize=13,TextColor3=C.TEXT,
				TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,
				Position=UDim2.fromOffset(16,0),Size=UDim2.new(1,-44,1,0),Parent=SHdr,
			})
			local arrLbl=N("TextLabel",{
				Text="V",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.TEXT_MUT,
				BackgroundTransparency=1,Rotation=expanded and 180 or 0,
				AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-12,0.5,0),Size=UDim2.fromOffset(14,14),Parent=SHdr,
			})

			local SCont=N("Frame",{
				Size=UDim2.new(1,-12,0,0),Position=UDim2.fromOffset(6,40),BackgroundTransparency=1,Parent=SBg,
			})
			local SLL=N("UIListLayout",{Padding=UDim.new(0,6),SortOrder=Enum.SortOrder.LayoutOrder,Parent=SCont})

			local function UpdSec()
				local h=SLL.AbsoluteContentSize.Y SCont.Size=UDim2.new(1,-12,0,h)
				TweenService:Create(SBg,SMOOTH,{Size=UDim2.new(1,0,0,expanded and h+46 or 36)}):Play()
			end
			if expanded then task.delay(0.1,UpdSec) end
			SLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdSec)
			SHdr.MouseButton1Click:Connect(function()
				expanded=not expanded
				TweenService:Create(arrLbl,FAST,{Rotation=expanded and 180 or 0}):Play()
				UpdSec()
			end)
			Hover(SHdr,SBg,C.GLASS,C.GLASS2)

			function Section:Button(cfg2) return BuildButton(SCont, cfg2, cfg2.Danger) end
			function Section:Toggle(cfg2) return BuildToggle(SCont, cfg2) end
			function Section:Slider(cfg2) return BuildSlider(SCont, cfg2) end
			function Section:Dropdown(cfg2) return BuildDropdown(SCont, cfg2, UpdSec) end
			function Section:Textbox(cfg2) return BuildTextbox(SCont, cfg2) end

			function Section:DualButton(c1,c2)
				local fr=N("Frame",{Size=UDim2.new(1,0,0,38),BackgroundTransparency=1,Parent=SCont})
				N("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,8),Parent=fr})
				local function Half(cfg2)
					local text=cfg2.Name or cfg2.Text or "Button" local cb=cfg2.Callback or function() end
					local bg=N("Frame",{Size=UDim2.new(0.5,-4,1,0),BackgroundColor3=C.CARD,BorderSizePixel=0,Parent=fr})
