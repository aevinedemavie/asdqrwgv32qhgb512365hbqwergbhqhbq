		function Tab:Paragraph(cfg2)
			local title=cfg2.Title or "Title" local content=cfg2.Content or ""
			local fr=N("Frame",{Size=UDim2.new(1,0,0,60),BackgroundColor3=C.CARD,BorderSizePixel=0,Parent=Tab._Page})
			Corner(8,fr) Stroke(C.BORDER,1,fr)
			local tlbl=N("TextLabel",{
				Font=Enum.Font.GothamBold,Text=title,TextSize=12,TextColor3=C.TEXT,
