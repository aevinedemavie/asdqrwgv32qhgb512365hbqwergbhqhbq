					Position=UDim2.fromOffset(10,0),Size=UDim2.new(1,-32,1,0),
					TextTruncate=Enum.TextTruncate.AtEnd,
					Parent=opt,
				})

				local check=N("ImageLabel",{
					Name="Check",
					Image=Icons.check,
					BackgroundTransparency=1,
					ImageColor3=ACCENT,
					ScaleType=Enum.ScaleType.Fit,
					AnchorPoint=Vector2.new(1,0.5),
					Position=UDim2.new(1,-8,0.5,0),
					Size=UDim2.fromOffset(13,13),
					Visible=false,
					Parent=opt,
				})

				opt.MouseEnter:Connect(function()
					local isSel = isMulti and selected[v] or (not isMulti and selected == v)
					if not isSel then TweenService:Create(bg,FAST,{BackgroundTransparency=0.92}):Play() end
				end)
				opt.MouseLeave:Connect(function()
					local isSel = isMulti and selected[v] or (not isMulti and selected == v)
					if not isSel then TweenService:Create(bg,FAST,{BackgroundTransparency=1}):Play() end
				end)
				opt.MouseButton1Click:Connect(function() Sel(v) end)

				optionButtons[v] = opt
				return opt
			end

			for i,v in ipairs(list) do CreateOption(v, i) end
			refreshVisualState()

			if isSearch then
				SBar:GetPropertyChangedSignal("Text"):Connect(function()
					local q=SBar.Text:lower() local cnt=0
					for v, btn in pairs(optionButtons) do
						local vis = q == "" or v:lower():find(q,1,true) ~= nil
						btn.Visible=vis if vis then cnt=cnt+1 end
					end
					local ch=math.min(cnt,5)*30
					Scroll.Size=UDim2.new(1,-12,0,ch)
					if expanded then
						fr.Size=UDim2.new(1,0,0,cYOff+ch+8)
						if sectionUpdate then sectionUpdate() end
					end
				end)
			end

			hdr.MouseButton1Click:Connect(function()
				expanded=not expanded
				local cnt=0 for _,b in pairs(optionButtons) do if b.Visible then cnt=cnt+1 end end
				local ch=math.min(math.max(cnt,1),5)*30
				Scroll.Size=UDim2.new(1,-12,0,ch)
				TweenService:Create(fr,SMOOTH,{Size=UDim2.new(1,0,0,expanded and (cYOff+ch+8) or 38)}):Play()
				TweenService:Create(arr,SMOOTH,{Rotation=expanded and 180 or 0}):Play()
				if sectionUpdate then task.delay(0.05, sectionUpdate) end
			end)
			Hover(hdr,fr,C.CARD,C.CARD_HOV)

			updSubtitle()

			local F={}
			function F:Set(val)
				if isMulti then
					selected={} if val and type(val)=="table" then for _,v in ipairs(val) do selected[v]=true end end
					local sl={} for k in pairs(selected) do table.insert(sl,k) end Library.Flags[flag]=sl cb(sl)
				else
					selected=val Library.Flags[flag]=val cb(val)
				end
				refreshVisualState()
			end
			function F:Get() return Library.Flags[flag] end
			function F:Refresh(newList)
				list=newList
				for _,c in pairs(OptH:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
				optionButtons = {}
				for i,v in ipairs(list) do CreateOption(v, i) end
				refreshVisualState()
				Scroll.CanvasSize=UDim2.new(0,0,0,#list*30)
				if expanded then
					local ch=math.min(#list,5)*30
					Scroll.Size=UDim2.new(1,-12,0,ch)
					fr.Size=UDim2.new(1,0,0,cYOff+ch+8)
					if sectionUpdate then sectionUpdate() end
				end
			end
			function F:Hide() fr.Visible=false end function F:Show() fr.Visible=true end
			Library.Items[flag]=F RegSearch(staticTitle,"dropdown",F,flag)
			return F
		end

		function Tab:Dropdown(cfg2) return BuildDropdown(Tab._Page, cfg2) end

		function Tab:Label(cfg2)
