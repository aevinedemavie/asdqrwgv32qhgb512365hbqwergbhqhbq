function Library:GetConfigFolder()
	local path = "ObsidiaHub/Configs/" .. tostring(game.GameId)
	if not isfolder("ObsidiaHub") then makefolder("ObsidiaHub") end
	if not isfolder("ObsidiaHub/Configs") then makefolder("ObsidiaHub/Configs") end
	if not isfolder(path) then makefolder(path) end
	return path
end

function Library:SaveConfig(name)
	writefile(self:GetConfigFolder() .. "/" .. name .. ".json", HttpService:JSONEncode(self.Flags))
	self:Notify({Title="Config Saved", Content="'" .. name .. "' saved.", Type="success", Time=3})
end

function Library:LoadConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok then
			for flag, val in pairs(dec) do
				if self.Items[flag] then pcall(function() self.Items[flag]:Set(val) end) end
			end
			self:Notify({Title="Config Loaded", Content="'" .. name .. "' applied.", Type="success", Time=3})
		else
			self:Notify({Title="Error", Content="Failed to decode config.", Type="error", Time=3})
		end
	else
		self:Notify({Title="Not Found", Content="No config named '" .. name .. "'.", Type="error", Time=3})
	end
end

function Library:DeleteConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then delfile(path) self:Notify({Title="Deleted", Content="'" .. name .. "' removed.", Type="warn", Time=3}) end
end

function Library:GetConfigs()
	local out = {}
	for _, f in ipairs(listfiles(self:GetConfigFolder())) do
		local n = f:match("([^/\\]+)%.json$")
		if n and n ~= "settings" then table.insert(out, n) end
	end
	return out
end

function Library:ExportConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok and setclipboard then
			setclipboard(HttpService:JSONEncode({Name=name, Data=dec}))
			self:Notify({Title="Exported", Content="Copied to clipboard.", Type="info", Time=3})
		end
	end
end

function Library:ImportConfig(str)
	if not str or str == "" then self:Notify({Title="Import Failed", Content="Paste JSON first.", Type="error", Time=3}) return false end
	local ok, dec = pcall(HttpService.JSONDecode, HttpService, str)
	if ok and dec.Name and dec.Data then
		writefile(self:GetConfigFolder() .. "/" .. dec.Name .. " (Imported).json", HttpService:JSONEncode(dec.Data))
		self:Notify({Title="Imported", Content="'" .. dec.Name .. " (Imported)' created.", Type="success", Time=3})
		return true
	end
	self:Notify({Title="Invalid", Content="Config format not recognized.", Type="error", Time=3})
	return false
end

function Library:SetAutoLoad(name, enabled)
	writefile(self:GetConfigFolder() .. "/settings.json",
		HttpService:JSONEncode({AutoLoadName = name or "", AutoLoadEnabled = enabled or false}))
end

function Library:GetAutoLoad()
	local path = self:GetConfigFolder() .. "/settings.json"
	if isfile(path) then
		local ok, dec = pcall(HttpService.JSONDecode, HttpService, readfile(path))
		if ok then return dec end
	end
	return {AutoLoadName = "", AutoLoadEnabled = false}
end

