function Library:ConfigManager(section)
	local configName = ""
	local nameInput, configList

	nameInput = section:Textbox({Name="Config Name", Placeholder="Enter name...", Wide=true, Callback=function(v) configName=v end})

	configList = section:Dropdown({Name="Config List", List=self:GetConfigs(), None=true, Callback=function(v)
		configName = v or ""
		if nameInput then nameInput:Set(v or "") end
	end})

	section:Divider("Actions")

	section:DualButton(
		{Name="Save", Callback=function()
			if configName~="" then self:SaveConfig(configName) configList:Refresh(self:GetConfigs())
			else self:Notify({Title="Error",Content="Enter a config name.",Type="error",Time=3}) end
		end},
		{Name="Load", Callback=function()
			if configName~="" then self:LoadConfig(configName)
			else self:Notify({Title="Error",Content="Select a config.",Type="error",Time=3}) end
		end}
	)

	section:DualButton(
		{Name="Overwrite", Callback=function()
			if configName~="" then self:SaveConfig(configName)
			else self:Notify({Title="Error",Content="Select a config.",Type="error",Time=3}) end
		end},
		{Name="Refresh", Callback=function() configList:Refresh(self:GetConfigs()) end}
	)

	section:Button({Name="Delete Config", Danger=true, Callback=function()
		if configName~="" then
			self:ConfirmDialog("Delete Config", "Are you sure? This cannot be undone.", function()
				self:DeleteConfig(configName) configList:Refresh(self:GetConfigs())
				configName="" if nameInput then nameInput:Set("") end
				configList:Set(nil)
			end)
		else self:Notify({Title="Error",Content="Select a config.",Type="error",Time=3}) end
	end})

	section:Divider("Share")

	section:Button({Name="Export Config", Callback=function()
		if configName~="" then self:ExportConfig(configName)
		else self:Notify({Title="Error",Content="Select a config.",Type="error",Time=3}) end
	end})

	local importStr = ""
	section:Textbox({Name="Import Data", Placeholder="Paste JSON...", Wide=true, Callback=function(v) importStr=v end})
	section:Button({Name="Import Config", Callback=function()
		if self:ImportConfig(importStr) then configList:Refresh(self:GetConfigs()) importStr="" end
	end})

	section:Divider("Auto-Load")

	local autoData = self:GetAutoLoad()
	local autoLabel
	section:Toggle({Name="Enable Auto-Load", Default=autoData.AutoLoadEnabled, NoSave=true, Callback=function(v)
		local d=self:GetAutoLoad() self:SetAutoLoad(d.AutoLoadName,v)
	end})
	section:Button({Name="Set as Auto-Load", Callback=function()
		if configName~="" then
			local d=self:GetAutoLoad() self:SetAutoLoad(configName,d.AutoLoadEnabled)
			if autoLabel then autoLabel:Set("Current: "..configName) end
			self:Notify({Title="Auto-Load Set",Content="'"..configName.."' will auto-load.",Type="info",Time=3})
		else self:Notify({Title="Error",Content="Select a config first.",Type="error",Time=3}) end
	end})
	autoLabel = section:Label({Text="Current: " .. (autoData.AutoLoadName~="" and autoData.AutoLoadName or "None")})
end

