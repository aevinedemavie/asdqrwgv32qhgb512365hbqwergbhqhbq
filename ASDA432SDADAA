					Position = UDim2.fromOffset(10, 45),
					BackgroundColor3 = SURFACE,
					PlaceholderText = "Search...",
					Text = "",
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = TEXT_MAIN,
					PlaceholderColor3 = TEXT_MUTED,
					TextXAlignment = "Left",
					Parent = DropdownBg
				}, {
					Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
					Create("UIStroke", {Color = BORDER_DIM, Thickness = 1}),
					Create("UIPadding", {PaddingLeft = UDim.new(0, 10)})
				})
			end

			local contentYOffset = isSearch and 80 or 45

			local Content = Create("ScrollingFrame", {
				Size = UDim2.new(1, -20, 0, math.min(#list, 4) * 32),
				Position = UDim2.fromOffset(10, contentYOffset),
				BackgroundTransparency = 1,
				ScrollBarThickness = 2,
				ScrollBarImageColor3 = ACCENT_DIM,
				CanvasSize = UDim2.new(0, 0, 0, #list * 32),
				Parent = DropdownBg
			})

			local DropHighlight
			if not isMulti then
				DropHighlight = Create("Frame", {
					Size = UDim2.new(1, 0, 0, 30),
					BackgroundColor3 = ACCENT,
					BackgroundTransparency = 0.88,
					Visible = false,
					ZIndex = 1,
					Parent = Content
				}, {
					Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
					Create("UIStroke", {Color = ACCENT_DIM, Thickness = 1, Transparency = 0.4})
				})
			end

			local OptionHolder = Create("Frame", {
				Size = UDim2.fromScale(1, 1),
				BackgroundTransparency = 1,
				ZIndex = 2,
				Parent = Content
			})

			local ListLayout = Create("UIListLayout", {
				Padding = UDim.new(0, 2),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = OptionHolder
			})

			local function UpdateHeader()
				if isMulti then
					local selectedList = {}
					for k, _ in pairs(selected) do table.insert(selectedList, k) end
					if #selectedList == 0 then
						TitleLabel.Text = text
					elseif #selectedList == 1 then
						TitleLabel.Text = selectedList[1]
					else
						TitleLabel.Text = selectedList[1] .. " (+" .. (#selectedList - 1) .. ")"
					end
				else
					TitleLabel.Text = selected or text
				end
			end

			if isSearch then
				SearchBar:GetPropertyChangedSignal("Text"):Connect(function()
					local input = SearchBar.Text:lower()
					local visibleCount = 0
					for _, b in pairs(OptionHolder:GetChildren()) do
						if b:IsA("TextButton") then
							if b.Text:lower():find(input) then
								b.Visible = true
								visibleCount = visibleCount + 1
							else
								b.Visible = false
							end
						end
					end
					local contentHeight = visibleCount * 32
					Content.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
					local clampedHeight = math.min(visibleCount, 4) * 32
					Content.Size = UDim2.new(1, -20, 0, clampedHeight)
					if expanded then
						DropdownBg.Size = UDim2.new(1, 0, 0, contentYOffset + clampedHeight + 10)
					end
				end)
			end

			local function Select(v, btn)
				if isMulti then
					if selected[v] then
						selected[v] = nil
						TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_DIM}):Play()
					else
						selected[v] = true
						TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = ACCENT}):Play()
					end
					local selectedList = {}
					for k, _ in pairs(selected) do table.insert(selectedList, k) end
					Library.Flags[flag] = selectedList
					UpdateHeader()
					callback(selectedList)
				else
					if isNone and selected == v then
						selected = nil
						DropHighlight.Visible = false
						TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_DIM}):Play()
						Library.Flags[flag] = nil
						UpdateHeader()
						callback(nil)
					else
						selected = v
						DropHighlight.Visible = true
						local targetY = (btn.AbsolutePosition.Y - Content.AbsolutePosition.Y) + Content.CanvasPosition.Y
						TweenService:Create(DropHighlight, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
							Position = UDim2.fromOffset(0, targetY)
						}):Play()
						for _, o in pairs(OptionHolder:GetChildren()) do
							if o:IsA("TextButton") then
								TweenService:Create(o, TweenInfo.new(0.2), {TextColor3 = TEXT_DIM}):Play()
							end
						end
						TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_MAIN}):Play()
						Library.Flags[flag] = v
						UpdateHeader()
						callback(v)
					end
				end
			end

			for i, v in pairs(list) do
				local Opt = Create("TextButton", {
					Text = v,
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = TEXT_DIM,
					Size = UDim2.new(1, 0, 0, 30),
					BackgroundTransparency = 1,
					LayoutOrder = i,
					Parent = OptionHolder
				})
				Opt.MouseButton1Click:Connect(function() Select(v, Opt) end)
				if isMulti then
					if selected[v] then Opt.TextColor3 = ACCENT end
				else
					if default and v == default then
						task.spawn(function()
							repeat task.wait() until Opt.AbsolutePosition.Y > 0
							Select(v, Opt)
						end)
					end
				end
			end

			if isMulti and default then UpdateHeader() end

			Header.MouseButton1Click:Connect(function()
				expanded = not expanded
				local visibleCount = 0
				for _, b in pairs(OptionHolder:GetChildren()) do
					if b:IsA("TextButton") and b.Visible then visibleCount = visibleCount + 1 end
				end
				local clampedHeight = math.min(visibleCount, 4) * 32
				Content.Size = UDim2.new(1, -20, 0, clampedHeight)
				Content.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 32)
				TweenService:Create(DropdownBg, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
					Size = UDim2.new(1, 0, 0, expanded and (contentYOffset + clampedHeight + 10) or 45)
				}):Play()
				TweenService:Create(Arrow, TweenInfo.new(0.4), {Rotation = expanded and 180 or 0}):Play()
			end)

			local DropdownFunctions = {}
			function DropdownFunctions:Set(val)
				if isMulti then
					selected = {}
					if val and type(val) == "table" then
						for _, v in pairs(val) do selected[v] = true end
					end
					for _, btn in pairs(OptionHolder:GetChildren()) do
						if btn:IsA("TextButton") then
							TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = selected[btn.Text] and ACCENT or TEXT_DIM}):Play()
						end
					end
					local selectedList = {}
					for k, _ in pairs(selected) do table.insert(selectedList, k) end
					Library.Flags[flag] = selectedList
					UpdateHeader()
					callback(selectedList)
				else
					selected = val
					Library.Flags[flag] = selected
					if selected then
						for _, btn in pairs(OptionHolder:GetChildren()) do
							if btn:IsA("TextButton") and btn.Text == selected then
								DropHighlight.Visible = true
								local targetY = (btn.AbsolutePosition.Y - Content.AbsolutePosition.Y) + Content.CanvasPosition.Y
								TweenService:Create(DropHighlight, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
									Position = UDim2.fromOffset(0, targetY)
								}):Play()
								TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_MAIN}):Play()
							elseif btn:IsA("TextButton") then
								TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_DIM}):Play()
							end
						end
					else
						if DropHighlight then DropHighlight.Visible = false end
						for _, btn in pairs(OptionHolder:GetChildren()) do
							if btn:IsA("TextButton") then
								TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = TEXT_DIM}):Play()
							end
						end
					end
					UpdateHeader()
					callback(selected)
				end
			end
			function DropdownFunctions:Refresh(newList)
				list = newList
				for _, child in pairs(OptionHolder:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				for i, v in pairs(list) do
					local Opt = Create("TextButton", {
						Text = v,
						Font = Enum.Font.GothamMedium,
						TextSize = 13,
						TextColor3 = TEXT_DIM,
						Size = UDim2.new(1, 0, 0, 30),
						BackgroundTransparency = 1,
						LayoutOrder = i,
						Parent = OptionHolder
					})
					Opt.MouseButton1Click:Connect(function() Select(v, Opt) end)
					if isMulti and selected[v] then
						Opt.TextColor3 = ACCENT
					elseif not isMulti and selected == v then
						Opt.TextColor3 = TEXT_MAIN
						if DropHighlight then
							DropHighlight.Visible = true
							DropHighlight.Position = UDim2.fromOffset(0, (i - 1) * 32 + 5)
						end
					end
				end
				local visibleCount = #list
				local clampedHeight = math.min(visibleCount, 4) * 32
				Content.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 32)
				if expanded then
					Content.Size = UDim2.new(1, -20, 0, clampedHeight)
					DropdownBg.Size = UDim2.new(1, 0, 0, contentYOffset + clampedHeight + 10)
				end
			end
			function DropdownFunctions:Hide() DropdownBg.Visible = false end
			function DropdownFunctions:Show() DropdownBg.Visible = true end
			Library.Items[flag] = DropdownFunctions
			return DropdownFunctions
		end

