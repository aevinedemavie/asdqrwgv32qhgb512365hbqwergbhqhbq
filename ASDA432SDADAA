local function Create(class, props, children)
	local obj = Instance.new(class)
	for k, v in pairs(props or {}) do obj[k] = v end
	for _, c in pairs(children or {}) do c.Parent = obj end
	return obj
end

local Library = {}
Library.__index = Library
Library.Flags = {}
Library.Items = {}
Library.ToggleKey = Enum.KeyCode.RightShift
local HttpService = game:GetService("HttpService")

function Library:GetConfigFolder()
	local gameId = tostring(game.GameId)
	local path = "ObsidiaHub/Configs/" .. gameId
	if not isfolder("ObsidiaHub") then makefolder("ObsidiaHub") end
	if not isfolder("ObsidiaHub/Configs") then makefolder("ObsidiaHub/Configs") end
	if not isfolder(path) then makefolder(path) end
	return path
end

function Library:SaveConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	local data = HttpService:JSONEncode(self.Flags)
	writefile(path, data)
	self:Notify({Title = "Config Saved", Content = "'" .. name .. "' has been saved.", Time = 3})
end

function Library:LoadConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local data = readfile(path)
		local success, decoded = pcall(function() return HttpService:JSONDecode(data) end)
		if success then
			for flag, value in pairs(decoded) do
				if self.Items[flag] then
					local s, e = pcall(function() self.Items[flag]:Set(value) end)
					if not s then warn("[Config Load Error] Flag: " .. tostring(flag) .. " | Error: " .. tostring(e)) end
				end
			end
			self:Notify({Title = "Config Loaded", Content = "'" .. name .. "' has been loaded.", Time = 3})
		else
			self:Notify({Title = "Error", Content = "Failed to decode config.", Time = 3})
		end
	else
		self:Notify({Title = "Error", Content = "Config file not found.", Time = 3})
	end
end

function Library:DeleteConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		delfile(path)
		self:Notify({Title = "Config Deleted", Content = "'" .. name .. "' has been deleted.", Time = 3})
	end
end

function Library:GetConfigs()
	local path = self:GetConfigFolder()
	local files = listfiles(path)
	local configs = {}
	for _, file in ipairs(files) do
		local fileName = file:match("([^/\\]+)%.json$")
		if fileName and fileName ~= "settings" then
			table.insert(configs, fileName)
		end
	end
	return configs
end

function Library:ExportConfig(name)
	local path = self:GetConfigFolder() .. "/" .. name .. ".json"
	if isfile(path) then
		local data = readfile(path)
		local success, decoded = pcall(function() return HttpService:JSONDecode(data) end)
		if success then
			local exportData = {Name = name, Data = decoded}
			local exportString = HttpService:JSONEncode(exportData)
			if setclipboard then
				setclipboard(exportString)
				self:Notify({Title = "Export Success", Content = "Config copied to clipboard!", Time = 3})
			else
				self:Notify({Title = "Export Failed", Content = "Executor does not support setclipboard.", Time = 3})
			end
		end
	else
		self:Notify({Title = "Error", Content = "Config file not found.", Time = 3})
	end
end

function Library:ImportConfig(jsonString)
	if not jsonString or jsonString == "" then
		return self:Notify({Title = "Error", Content = "Please paste config data first.", Time = 3})
	end
	local success, decoded = pcall(function() return HttpService:JSONDecode(jsonString) end)
	if success and decoded.Name and decoded.Data then
		local newName = decoded.Name .. " - ( Imported )"
		local path = self:GetConfigFolder() .. "/" .. newName .. ".json"
		local data = HttpService:JSONEncode(decoded.Data)
		writefile(path, data)
		self:Notify({Title = "Import Success", Content = "Config '" .. newName .. "' created!", Time = 3})
		return true
	else
		self:Notify({Title = "Error", Content = "Invalid config data format.", Time = 3})
		return false
	end
end

function Library:SetAutoLoad(name, enabled)
	local path = self:GetConfigFolder() .. "/settings.json"
	local settings = {AutoLoadName = name or "", AutoLoadEnabled = enabled or false}
	writefile(path, HttpService:JSONEncode(settings))
end

function Library:GetAutoLoad()
	local path = self:GetConfigFolder() .. "/settings.json"
	if isfile(path) then
		local data = readfile(path)
		local success, decoded = pcall(function() return HttpService:JSONDecode(data) end)
		if success then return decoded end
	end
	return {AutoLoadName = "", AutoLoadEnabled = false}
end

function Library:ConfigManager(section)
	section:Paragraph({Title = "Configuration Manager", Content = "Manage your saved configurations below."})

	local configName = ""
	local nameInput
	local configList

	nameInput = section:Textbox({
		Name = "Config Name",
		Placeholder = "Enter config name...",
		Callback = function(val) configName = val end
	})

	configList = section:Dropdown({
		Name = "Config List",
		List = self:GetConfigs(),
		Callback = function(val)
			configName = val
			if nameInput then nameInput:Set(val) end
		end
	})

	section:DualButton({
		Name = "Create Config",
		Callback = function()
			if configName ~= "" then
				self:SaveConfig(configName)
				configList:Refresh(self:GetConfigs())
			else
				self:Notify({Title = "Error", Content = "Please enter a config name.", Time = 3})
			end
		end
	}, {
		Name = "Load Config",
		Callback = function()
			if configName ~= "" then
				self:LoadConfig(configName)
			else
				self:Notify({Title = "Error", Content = "Please select a config.", Time = 3})
			end
		end
	})

	section:DualButton({
		Name = "Overwrite Config",
		Callback = function()
			if configName ~= "" then
				self:SaveConfig(configName)
			else
				self:Notify({Title = "Error", Content = "Please select a config.", Time = 3})
			end
		end
	}, {
		Name = "Refresh List",
		Callback = function()
			configList:Refresh(self:GetConfigs())
		end
	})

	section:Button({
		Name = "Delete Config",
		Callback = function()
			if configName ~= "" then
				self:DeleteConfig(configName)
				configList:Refresh(self:GetConfigs())
				configName = ""
				if nameInput then nameInput:Set("") end
			else
				self:Notify({Title = "Error", Content = "Please select a config.", Time = 3})
			end
		end
	})

	section:Paragraph({Title = "Share Configuration", Content = "Export settings to clipboard or import from a shared JSON string."})

	section:Button({
		Name = "Export Selected Config",
		Callback = function()
			if configName ~= "" then
				self:ExportConfig(configName)
			else
				self:Notify({Title = "Error", Content = "Please select a config to export.", Time = 3})
			end
		end
	})

	local importData = ""
	section:Textbox({
		Name = "Import Config Data",
		Placeholder = "Paste JSON here...",
		Callback = function(val) importData = val end
	})

	section:Button({
		Name = "Import Config",
		Callback = function()
			if self:ImportConfig(importData) then
				configList:Refresh(self:GetConfigs())
			end
		end
	})

	section:Paragraph({Title = "Auto-Load Configuration", Content = "Set a configuration to be automatically loaded upon script execution."})

	local autoData = self:GetAutoLoad()
	local currentAutoLoadLabel = section:Label({Text = "Current Auto-Load: " .. (autoData.AutoLoadName ~= "" and autoData.AutoLoadName or "None")})

	section:Toggle({
		Name = "Enable Auto-Load Config",
		Default = autoData.AutoLoadEnabled,
		NoSave = true,
		Callback = function(val)
			local currentData = self:GetAutoLoad()
			self:SetAutoLoad(currentData.AutoLoadName, val)
		end
	})

	section:Button({
		Name = "Set as Auto-Load",
		Callback = function()
			if configName ~= "" then
				local currentData = self:GetAutoLoad()
				self:SetAutoLoad(configName, currentData.AutoLoadEnabled)
				currentAutoLoadLabel:Set("Current Auto-Load: " .. configName)
				self:Notify({Title = "Success", Content = "Config '" .. configName .. "' set as auto-load.", Time = 3})
			else
				self:Notify({Title = "Error", Content = "Please select/enter a config name first.", Time = 3})
			end
		end
	})
end

function Library.SettingManager()
	local Manager = {}
	function Manager:AddToTab(tab)
		tab:Paragraph({
			Title = "UI Settings",
			Content = "Manage the interface settings and keybindings here."
		})
		tab:Keybind({
			Name = "UI Toggle Key",
			Default = Library.ToggleKey,
			OnChange = function(New)
				Library.ToggleKey = New
			end
		})
		tab:Button({
			Name = "Unload UI",
			Callback = function()
				local core = gethui() or Player:WaitForChild("PlayerGui")
				local gui = core:FindFirstChild("ObsidiaHub_UI") or Player.PlayerGui:FindFirstChild("ObsidiaHub_UI")
				if gui then gui:Destroy() end
			end
		})
	end
	return Manager
end

