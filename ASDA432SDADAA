			local current = self.Main.Position
			local distance = math.abs(targetPosition.X.Offset - current.X.Offset) + math.abs(targetPosition.Y.Offset - current.Y.Offset)
			if dragging or distance > 1 then
				local lerpSpeed = dragging and 0.1 or 0.15
				self.Main.Position = UDim2.new(
					current.X.Scale + (targetPosition.X.Scale - current.X.Scale) * lerpSpeed,
					current.X.Offset + (targetPosition.X.Offset - current.X.Offset) * lerpSpeed,
					current.Y.Scale + (targetPosition.Y.Scale - current.Y.Scale) * lerpSpeed,
					current.Y.Offset + (targetPosition.Y.Offset - current.Y.Offset) * lerpSpeed
				)
			end
		end)

		self.Top.InputBegan:Connect(function(input)
			if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
				dragging = true
				dragStart = input.Position
				startPos = self.Main.Position
				input.Changed:Connect(function()
